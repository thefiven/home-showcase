# dependencies
node_modules/

# env files (never commit real secrets)
.env
.env.*
!.env.example

# next.js (apps/web)
apps/web/.next/
apps/web/out/
apps/web/next-env.d.ts
apps/web/*.tsbuildinfo

# strapi (apps/cms)
apps/cms/.strapi/
apps/cms/.cache/
apps/cms/dist/
apps/cms/build/
apps/cms/.tmp/
apps/cms/*.tsbuildinfo
# user-uploaded media (local dev only — never commit real uploads)
apps/cms/public/uploads/*
!apps/cms/public/uploads/.gitkeep
# seed data assets (real property photos — never commit, see apps/cms/scripts/seed-property.ts)
apps/cms/seed-data/
# regenerated by `strapi develop`/`build` on every run — not hand-authored
apps/cms/types/generated/

# test coverage reports (apps/web, apps/cms — pnpm test:coverage)
coverage/

# Playwright (e2e/ — issue #12)
e2e/playwright-report/
e2e/test-results/
e2e/tests/.auth/
apps/cms/.tmp/e2e.db*

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor
.DS_Store
.vscode/*
!.vscode/extensions.json
