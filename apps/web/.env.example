# Variables d'environnement pour `apps/web` (Next.js).
# En développement via `pnpm docker:up`, ces variables sont fournies par
# `docker/.env` (voir `docker/.env.example`) — ce fichier documente le besoin
# pour une exécution de `apps/web` hors Docker.

# URL publique de Strapi, résolue par le navigateur (fetchs côté client,
# construction des URLs de médias affichées dans le HTML).
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# URL de Strapi résolue côté serveur pour les appels SSR/ISR (Next.js).
# Dans docker-compose, c'est l'hôte du conteneur `cms` sur le réseau interne
# (http://cms:1337) ; hors Docker, la même valeur que NEXT_PUBLIC_STRAPI_URL.
STRAPI_INTERNAL_URL=http://localhost:1337
