HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database (sqlite by default for local dev without Docker).
# For Postgres via Docker (issue #2), see docker/.env.example instead —
# this file stays sqlite for the non-Docker local fallback.
#
# Strapi's env() helper treats a present-but-empty variable as a real value,
# NOT as "unset" — it will NOT fall back to its coded default. Every
# DATABASE_* key below must either be left unset entirely (comment it out)
# or given an explicit value; a bare "KEY=" silently breaks the connection.
# This bit us once already with DATABASE_FILENAME (see git history) — if you
# switch DATABASE_CLIENT to postgres here, fill in every value below.
DATABASE_CLIENT=sqlite
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SSL=false
DATABASE_FILENAME=.tmp/data.db

# iCal sync (issue #7): imports each Property's Airbnb iCal export into
# Availability on a schedule. Cron is enabled by default — set CRON_ENABLED=false
# to turn it off (e.g. to avoid hitting real Airbnb URLs from a throwaway
# environment). ICAL_SYNC_CRON is a standard 5-field cron expression (default:
# hourly, at minute 0 — see SPEC.md §5).
CRON_ENABLED=true
ICAL_SYNC_CRON="0 * * * *"

# Notification email (issue #10): sent to the owner on every new booking
# request. Provider-agnostic SMTP (nodemailer) — works with a self-hosted
# relay or any SaaS SMTP endpoint (e.g. Resend's smtp.resend.com), so
# switching provider only means changing these values, not the code.
# Leave SMTP_HOST empty to skip sending (e.g. local dev without a mailer).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
EMAIL_FROM=no-reply@home-showcase.local
EMAIL_REPLY_TO=no-reply@home-showcase.local
# Recipient of booking request notifications (the owner) + admin base URL
# used to build the link to the booking request in the email.
OWNER_NOTIFICATION_EMAIL=
ADMIN_URL=http://localhost:1337/admin
