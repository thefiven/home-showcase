HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database (sqlite by default for local dev without Docker — see issue #2 for Postgres)
#
# Strapi's env() helper treats a present-but-empty variable as a real value,
# NOT as "unset" — it will NOT fall back to its coded default. Every
# DATABASE_* key below must either be left unset entirely (comment it out)
# or given an explicit value; a bare "KEY=" silently breaks the connection.
# This bit us once already with DATABASE_FILENAME (see git history) — when
# issue #2 switches DATABASE_CLIENT to postgres, fill in every value below.
DATABASE_CLIENT=sqlite
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SSL=false
DATABASE_FILENAME=.tmp/data.db
