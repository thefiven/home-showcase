{
  "kind": "collectionType",
  "collectionName": "properties",
  "info": {
    "singularName": "property",
    "pluralName": "properties",
    "displayName": "Property",
    "description": "A property showcased on the site (Airbnb-style listing)."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "description": {
      "type": "blocks",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "shortDescription": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "maxGuests": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "location": {
      "type": "component",
      "component": "shared.location",
      "repeatable": false,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "pricing": {
      "type": "component",
      "component": "property.pricing",
      "repeatable": false,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "amenities": {
      "type": "component",
      "component": "shared.amenity",
      "repeatable": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "icalUrl": {
      "type": "string",
      "private": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "availabilities": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::availability.availability",
      "mappedBy": "property"
    },
    "bookingRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::booking-request.booking-request",
      "mappedBy": "property"
    }
  }
}
