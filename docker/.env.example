# Variables d'environnement pour `docker compose` (voir README.md).
# Copier ce fichier en `docker/.env` puis renseigner de vraies valeurs
# (jamais ce fichier .env.example, qui reste versionné).
#
# Rappel (voir apps/cms/.env.example) : pour Strapi, une variable présente
# mais vide ("KEY=") est traitée comme une valeur réelle, PAS comme "absente"
# — elle ne retombe pas sur son défaut. Toutes les variables ci-dessous
# doivent avoir une valeur explicite.

# --- PostgreSQL --------------------------------------------------------
# Consommées directement par l'image officielle postgres.
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=changeme

# --- Strapi (apps/cms) — connexion à Postgres --------------------------
# DATABASE_NAME/USERNAME/PASSWORD doivent être identiques à
# POSTGRES_DB/USER/PASSWORD ci-dessus : c'est la même base.
# DATABASE_CLIENT et DATABASE_HOST sont fixés par docker-compose.yml
# (postgres, résolu via le réseau Docker) et ne doivent pas être redéfinis ici.
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=changeme
DATABASE_SSL=false

# --- Strapi — secrets applicatifs --------------------------------------
# À régénérer pour un usage réel, ex. : openssl rand -base64 32
APP_KEYS=toBeModified1,toBeModified2
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# --- Next.js (apps/web) -------------------------------------------------
# URL publique (résolue par le navigateur) et URL interne au réseau Docker
# (résolue par le conteneur web pour les appels SSR, ex. cms:1337).
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_INTERNAL_URL=http://cms:1337
