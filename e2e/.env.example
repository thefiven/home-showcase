# Variables d'environnement pour les tests E2E (Playwright, issue #12).
# Toutes ont une valeur par défaut sûre pour un run local/CI contre la stack
# jetable démarrée par `e2e/run.sh` — inutile de créer un `.env` sauf pour
# pointer vers une stack différente.

# URLs de la stack lancée par `e2e/run.sh` (SQLite éphémère, voir ce script).
E2E_WEB_URL=http://127.0.0.1:3000
E2E_STRAPI_URL=http://127.0.0.1:1337

# Identifiants du compte admin créé par le global-setup (compte jetable,
# valable uniquement pour la durée du run E2E — pas un vrai secret).
E2E_ADMIN_EMAIL=e2e-admin@home-showcase.local
E2E_ADMIN_PASSWORD=E2eTestPassword1

# Slug du logement de test créé/réutilisé par le global-setup.
E2E_PROPERTY_SLUG=villa-e2e
